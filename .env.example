# Bas-URL till backend-appen (Railway), t.ex. https://maendekollen-production.up.railway.app
MAENDEKOLL_API_URL=

# Samma delade admin-nyckel som backend-repot förväntar sig som Bearer-token
ADMIN_API_KEY=

# Auth.js — signeringsnyckel för sessioner, generera med `npx auth secret`
AUTH_SECRET=

# Slack-appens OAuth-uppgifter (samma Slack-app som boten), från
# api.slack.com/apps -> appen -> "Sign In with Slack" / OAuth & Permissions
AUTH_SLACK_ID=
AUTH_SLACK_SECRET=

# Sätt till "true" för att inkludera testdata (?dataset=all) i alla anrop
# mot bot+API:et — bra lokalt under utveckling. Lämna tomt/utelämna i
# produktion (default är skarp data, dvs. oförändrat beteende).
MAENDEKOLL_INCLUDE_TEST_DATA=
